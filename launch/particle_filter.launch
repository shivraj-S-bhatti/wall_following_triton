<launch>
    <arg name="world_file" default="$(find turtlebot3_gazebo)/worlds/turtlebot3_house.world"/>
    <arg name="robot_name" default="triton"/>
    <arg name="sdf_robot_file" default="$(find cs603_particle_filter)/models/$(arg robot_name)/model.sdf"/>
    <arg name="params_file" default="$(find cs603_particle_filter)/config/particle_filter_params.yaml"/>
    <arg name="map_yaml" default="$(find cs603_particle_filter)/maps/house_map.yaml"/>
    <arg name="metric_map_output_png" default="$(find cs603_particle_filter)/artifacts/house_metric_map.png"/>
    <arg name="likelihood_field_output_png" default="$(find cs603_particle_filter)/artifacts/house_likelihood_field.png"/>
    <arg name="likelihood_field_cache" default="$(find cs603_particle_filter)/artifacts/house_likelihood_field.npz"/>
    <arg name="csv_log_path" default="$(find cs603_particle_filter)/artifacts/pf_run.csv"/>
    <arg name="num_particles" default="350"/>
    <arg name="init_mode" default="global"/>
    <arg name="beam_step" default="8"/>
    <arg name="sigma_hit" default="0.20"/>
    <arg name="resample_min_neff_ratio" default="1.0"/>
    <arg name="publish_map_to_odom_tf" default="false"/>
    <arg name="map_to_odom_x" default="0.0"/>
    <arg name="map_to_odom_y" default="0.0"/>
    <arg name="map_to_odom_yaw" default="0.0"/>
    <arg name="x" default="-3.0" />
    <arg name="y" default="1.0" />
    <arg name="z" default="0.0" />
    <arg name="roll" default="0.0" />
    <arg name="pitch" default="0.0" />
    <arg name="yaw" default="0.0" />
  
    <include file="$(find gazebo_ros)/launch/empty_world.launch">
      <arg name="use_sim_time" value="true"/>
      <arg name="debug" value="false "/>  <!-- false for real training, true for debugging -->
      <arg name="paused" value="false"/>
      <arg name="gui" value="true" />
      <arg name="world_name" value="$(arg world_file)"/>
      <arg name="verbose" value="true"/>
      <arg name="recording" value="false"/>
    </include>

    <node pkg="gazebo_ros" type="spawn_model" name="$(arg robot_name)_spawn_urdf" respawn="false" output="screen" 
    args="-file $(arg sdf_robot_file) -sdf -x $(arg x) -y $(arg y) -z $(arg z) -R $(arg roll) -P $(arg pitch) -Y $(arg yaw) -model $(arg robot_name)" />
    
    <node pkg="tf" type="static_transform_publisher" name="base_link_to_base_scan" args="0 0 0.161 0 0 0 /base_link /base_scan 100" />
    <node pkg="tf" type="static_transform_publisher" name="map_to_odom" args="$(arg map_to_odom_x) $(arg map_to_odom_y) 0 $(arg map_to_odom_yaw) 0 0 /map /odom 100" />
    <node pkg="map_server" type="map_server" name="map_server" args="$(arg map_yaml)" />
    <node pkg="cs603_particle_filter" type="position_publisher.py" name="position_publisher" />
    <node pkg="cs603_particle_filter"
          type="particle_filter.py"
          name="particle_filter"
          output="screen"
          respawn="false">
      <rosparam command="load" file="$(arg params_file)"/>
      <param name="map_yaml" value="$(arg map_yaml)"/>
      <param name="metric_map_output_png" value="$(arg metric_map_output_png)"/>
      <param name="likelihood_field_output_png" value="$(arg likelihood_field_output_png)"/>
      <param name="likelihood_field_cache" value="$(arg likelihood_field_cache)"/>
      <param name="csv_log_path" value="$(arg csv_log_path)"/>
      <param name="num_particles" value="$(arg num_particles)"/>
      <param name="init_mode" value="$(arg init_mode)"/>
      <param name="beam_step" value="$(arg beam_step)"/>
      <param name="sigma_hit" value="$(arg sigma_hit)"/>
      <param name="resample_min_neff_ratio" value="$(arg resample_min_neff_ratio)"/>
      <param name="publish_map_to_odom_tf" value="$(arg publish_map_to_odom_tf)"/>
    </node>

    <node pkg="rviz" type="rviz" name="rviz" args="-d $(find cs603_particle_filter)/rviz/lidar.rviz" />
    
</launch>

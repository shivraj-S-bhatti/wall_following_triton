<launch>
  <arg name="qtable_input_path" default="$(find wall_following_triton)/config/qtable_d2_sarsa_best.yaml"/>
  <arg name="qtable_output_path" default="$(find wall_following_triton)/config/qtable_d2_sarsa_best.yaml"/>
  <arg name="metrics_csv_path" default="$(find wall_following_triton)/artifacts/d2_sarsa_metrics.csv"/>
  <arg name="eval_csv_path" default="$(find wall_following_triton)/artifacts/d2_sarsa_eval.csv"/>
  <arg name="control_hz" default="6.0"/>
  <arg name="acquire_wall_enabled" default="true"/>
  <arg name="test_start_enabled" default="false"/>
  <arg name="test_start_x" default="0.0"/>
  <arg name="test_start_y" default="0.0"/>
  <arg name="test_start_yaw" default="0.0"/>
  <arg name="test_start_z" default="0.0"/>
  <arg name="test_deadlock_breaker_enabled" default="false"/>

  <include file="$(find wall_following_triton)/launch/wf_d2.launch">
    <arg name="algorithm" value="sarsa"/>
    <arg name="mode" value="test"/>
    <arg name="qtable_input_path" value="$(arg qtable_input_path)"/>
    <arg name="qtable_output_path" value="$(arg qtable_output_path)"/>
    <arg name="metrics_csv_path" value="$(arg metrics_csv_path)"/>
    <arg name="eval_csv_path" value="$(arg eval_csv_path)"/>
    <arg name="control_hz" value="$(arg control_hz)"/>
    <arg name="acquire_wall_enabled" value="$(arg acquire_wall_enabled)"/>
    <arg name="test_start_enabled" value="$(arg test_start_enabled)"/>
    <arg name="test_start_x" value="$(arg test_start_x)"/>
    <arg name="test_start_y" value="$(arg test_start_y)"/>
    <arg name="test_start_yaw" value="$(arg test_start_yaw)"/>
    <arg name="test_start_z" value="$(arg test_start_z)"/>
    <arg name="test_deadlock_breaker_enabled" value="$(arg test_deadlock_breaker_enabled)"/>
  </include>
</launch>

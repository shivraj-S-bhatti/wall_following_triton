<launch>
  <!-- Deliverable 1 demo: start the provided simulation and the policy node. -->
  <include file="$(find stingray_sim)/launch/wall_following.launch"/>

  <node pkg="wall_following_triton"
        type="wf_policy_node.py"
        name="wf_policy_node"
        output="screen"
        respawn="false">
    <param name="scan_topic" value="/scan"/>
    <param name="cmd_topic" value="/cmd_vel"/>

    <param name="qtable_path" value="$(find wall_following_triton)/config/qtable_d1.yaml"/>
    <param name="actions_path" value="$(find wall_following_triton)/config/actions.yaml"/>

    <param name="front_too_close" value="0.55"/>
    <param name="right_too_close" value="0.55"/>
    <param name="right_too_far" value="0.95"/>
    <param name="heading_parallel_tolerance" value="0.10"/>
    <param name="front_sector_start_deg" value="75.0"/>
    <param name="front_sector_end_deg" value="105.0"/>
    <param name="right_front_sector_start_deg" value="20.0"/>
    <param name="right_front_sector_end_deg" value="70.0"/>
    <param name="right_rear_sector_start_deg" value="-70.0"/>
    <param name="right_rear_sector_end_deg" value="-20.0"/>
    <param name="acquire_wall_enabled" value="true"/>
    <param name="acquire_wall_distance" value="1.40"/>
    <param name="acquire_angle_soft_deg" value="20.0"/>
    <param name="acquire_angle_hard_deg" value="55.0"/>

    <param name="collision_action" value="turn_left_hard"/>
  </node>
</launch>
